# Configuration Matrix Bot

# Serveur Matrix
MATRIX_HOMESERVER=
MATRIX_USER_ID=
MATRIX_PASSWORD=
MATRIX_ACCESS_TOKEN=

# Espace de jeu
MATRIX_SPACE_ID=
MATRIX_LOBBY_ROOM_ID=

# Configuration du jeu
GAME_START_DAY=  # 0=Lundi, 6=Dimanche
GAME_START_HOUR=
GAME_MAX_DURATION_DAYS=

# Horaires
NIGHT_START_HOUR=
DAY_START_HOUR=
VOTE_START_HOUR=
SORCIERE_MIN_HOURS=

MATRIX_RUN_TESTS=false  # Si true, exécute les tests d'intégration au premier lancement (BDD vide)
# Préfixe des commandes (par défaut "!"). 
# "/" est réservé par les clients Matrix mobiles, préférez "!" ou un autre caractère.
COMMAND_PREFIX=!

# Rôles spéciaux
# Petite Fille : Espionne les loups-garous la nuit
# Si true, les messages sont légèrement altérés (simulation d'écoute derrière la porte)
# Si false, les messages sont transmis tels quels (sans l'auteur)
LITTLE_GIRL_DISTORT_MESSAGES=false
# Mentaliste : Peut savoir X heure avant la fin du vote si l'issu du vote est positive ou négative.
MENTALISTE_ADVANCE_HOURS=2